# Application Port
PORT=5000

# MongoDB Connection String (Defaults to local if empty)
MONGO_URI=mongodb://127.0.0.1:27017/tailoring_db

# Security
JWT_SECRET=your_super_secret_jwt_key_here

# Email Configuration (Used for password resets)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_gmail_app_password
